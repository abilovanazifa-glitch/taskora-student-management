# App

NEXT_PUBLIC_APP_URL=http://localhost:3000



# PostgreSQL (Prisma)

# Local example:

# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskora?schema=public"

# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/taskora?schema=public"

#

# Neon / Vercel Postgres example:

# DATABASE_URL="postgresql://USER:PASSWORD@HOST/taskora?sslmode=require&pgbouncer=true"

# DIRECT_URL="postgresql://USER:PASSWORD@HOST/taskora?sslmode=require"

DATABASE_URL=

DIRECT_URL=



# Auth.js

AUTH_SECRET=

AUTH_URL=http://localhost:3000



# Vercel Cron — required in production for /api/cron/reminders

# Vercel sends: Authorization: Bearer <CRON_SECRET>

CRON_SECRET=



# Translation service for JA <-> UZ user content (DeepL)

# Free tier: https://api-free.deepl.com/v2/translate

# Pro tier:  https://api.deepl.com/v2/translate

TRANSLATION_API_KEY=

# Optional override (defaults to DeepL free API URL)

# TRANSLATION_API_URL=https://api-free.deepl.com/v2/translate

# Max translation requests per authenticated user per minute (default: 20)

TRANSLATION_RATE_LIMIT_PER_MINUTE=20

