generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PreferredLanguage {
  UZ
  JA
  EN
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ProjectMemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
  CANCELLED
}

enum NotificationType {
  DEADLINE_REMINDER
  TASK_ASSIGNED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_OVERDUE
  PROJECT_INVITATION
  INVITATION_ACCEPTED
  ROLE_CHANGED
  EVENT_UPCOMING
  SYSTEM
}

enum ReminderOffsetType {
  ONE_DAY_BEFORE
  THREE_HOURS_BEFORE
  ONE_HOUR_BEFORE
  CUSTOM
}

enum ReminderTargetType {
  TASK
  EVENT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

model User {
  id                String            @id @default(cuid())
  fullName          String
  email             String            @unique
  passwordHash      String
  avatarUrl         String?
  preferredLanguage PreferredLanguage @default(JA)
  theme             Theme             @default(SYSTEM)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  ownedProjects   Project[]       @relation("ProjectOwner")
  projectMembers  ProjectMember[]
  ownedSubjects   Subject[]       @relation("SubjectOwner")
  ownedTags       Tag[]           @relation("TagOwner")
  createdTasks    Task[]          @relation("TaskCreator")
  assignedTasks   Task[]          @relation("TaskAssignee")
  calendarEvents  CalendarEvent[] @relation("CalendarEventCreator")
  notifications   Notification[]
  reminders         Reminder[]
  sentInvitations Invitation[]    @relation("InvitationInviter")
  taskComments    TaskComment[]   @relation("TaskCommentAuthor")

  @@index([preferredLanguage])
  @@index([createdAt])
  @@map("users")
}

model Project {
  id            String        @id @default(cuid())
  nameUz        String
  nameJa        String
  descriptionUz String        @db.Text
  descriptionJa String        @db.Text
  color         String
  ownerId       String
  startDate     DateTime?
  endDate       DateTime?
  status        ProjectStatus @default(PLANNED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  owner          User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members        ProjectMember[]
  tasks          Task[]
  calendarEvents CalendarEvent[]
  invitations    Invitation[]

  @@index([ownerId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
  @@map("projects")
}

model ProjectMember {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  role      ProjectMemberRole @default(MEMBER)
  joinedAt  DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
  @@index([role])
  @@map("project_members")
}

model Subject {
  id        String   @id @default(cuid())
  nameUz    String
  nameJa    String
  color     String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User   @relation("SubjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([ownerId])
  @@index([createdAt])
  @@map("subjects")
}

model Task {
  id            String       @id @default(cuid())
  titleUz       String
  titleJa       String
  descriptionUz String       @db.Text
  descriptionJa String       @db.Text
  projectId     String
  subjectId     String?
  creatorId     String
  assigneeId    String?
  priority      TaskPriority @default(MEDIUM)
  status        TaskStatus   @default(TODO)
  startDate     DateTime?
  deadline      DateTime?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subject       Subject?       @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  creator       User           @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  assignee      User?          @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  tags          TaskTag[]
  notifications Notification[]
  reminders     Reminder[]
  checklists    TaskChecklist[]
  comments      TaskComment[]
  attachments   TaskAttachment[]

  @@index([projectId])
  @@index([subjectId])
  @@index([creatorId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([deadline])
  @@index([startDate])
  @@index([completedAt])
  @@index([projectId, status])
  @@index([projectId, deadline])
  @@index([assigneeId, status])
  @@map("tasks")
}

model Tag {
  id        String   @id @default(cuid())
  nameUz    String
  nameJa    String
  color     String
  ownerId   String
  createdAt DateTime @default(now())

  owner User      @relation("TagOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tasks TaskTag[]

  @@index([ownerId])
  @@index([createdAt])
  @@map("tags")
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
  @@map("task_tags")
}

model TaskChecklist {
  id        String   @id @default(cuid())
  taskId    String
  titleUz   String
  titleJa   String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task  Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items TaskChecklistItem[]

  @@index([taskId])
  @@map("task_checklists")
}

model TaskChecklistItem {
  id          String   @id @default(cuid())
  checklistId String
  titleUz     String
  titleJa     String
  isCompleted Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checklist TaskChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
  @@map("task_checklist_items")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  bodyUz    String   @db.Text
  bodyJa    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([authorId])
  @@map("task_comments")
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  name      String
  url       String
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_attachments")
}

model CalendarEvent {
  id            String   @id @default(cuid())
  titleUz       String
  titleJa       String
  descriptionUz String   @db.Text
  descriptionJa String   @db.Text
  startAt       DateTime
  endAt         DateTime
  allDay        Boolean  @default(false)
  locationUz    String?
  locationJa    String?
  projectId     String?
  creatorId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User     @relation("CalendarEventCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  reminders Reminder[]
  notifications Notification[]

  @@index([projectId])
  @@index([creatorId])
  @@index([startAt])
  @@index([endAt])
  @@index([startAt, endAt])
  @@map("calendar_events")
}

model Notification {
  id            String           @id @default(cuid())
  userId        String
  type          NotificationType
  titleUz       String
  titleJa       String
  messageUz     String           @db.Text
  messageJa     String           @db.Text
  relatedTaskId String?
  relatedEventId String?
  dedupeKey     String?          @unique
  isRead        Boolean          @default(false)
  scheduledAt   DateTime?
  sentAt        DateTime?
  createdAt     DateTime         @default(now())

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedTask  Task?          @relation(fields: [relatedTaskId], references: [id], onDelete: SetNull)
  relatedEvent CalendarEvent? @relation(fields: [relatedEventId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, isRead])
  @@index([type])
  @@index([scheduledAt])
  @@index([sentAt])
  @@index([createdAt])
  @@index([dedupeKey])
  @@map("notifications")
}

model Reminder {
  id         String             @id @default(cuid())
  userId     String
  targetType ReminderTargetType
  taskId     String?
  eventId    String?
  offsetType ReminderOffsetType
  customAt   DateTime?
  remindAt   DateTime
  sentAt     DateTime?
  dedupeKey  String             @unique
  createdAt  DateTime           @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  task  Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  event CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([remindAt, sentAt])
  @@index([taskId])
  @@index([eventId])
  @@map("reminders")
}

model Invitation {
  id           String            @id @default(cuid())
  projectId    String
  inviterId    String
  invitedEmail String
  role         ProjectMemberRole @default(MEMBER)
  token        String            @unique
  status       InvitationStatus  @default(PENDING)
  expiresAt    DateTime
  createdAt    DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter User    @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([inviterId])
  @@index([invitedEmail])
  @@index([status])
  @@index([expiresAt])
  @@map("invitations")
}
